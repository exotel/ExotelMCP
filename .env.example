# ExotelMCP Server Configuration
# Copy this to .env and fill in your values

# Server
PORT=8080

# VoiceBot defaults (only needed if NOT passing via Authorization header)
VOICEBOT_API_KEY=
VOICEBOT_API_TOKEN=
VOICEBOT_ACCOUNT_ID=
VOICEBOT_BASE_URL=https://voicebot.in.exotel.com/voicebot/api/v2

# Calls API defaults
CALLS_BASE_URL=https://api.in.exotel.com
CALLS_ACCOUNT_SID=
CALLS_API_KEY=
CALLS_API_TOKEN=
CALLS_FORCE_HTTP=false

# Default caller ID for outbound calls
DEFAULT_CALLER_ID=

# SSL verification (set false only for QA environments)
SSL_VERIFY=true

# Session cookies (optional, dev only)
VOICEBOT_SESSION_COOKIE=
DEVICE_SESSION_COOKIE=

# Callback URL for webhooks
EXOTEL_CALLBACK_URL=http://localhost:8080

# H2 database password
H2_PASSWORD=password
